{
  "stockbitBaseUrl": "https://exodus.stockbit.com",
  "endpoints": {
    "ihsgChart": "/charts/ihsg/daily",
    "ihsgInfo": "/emitten/IHSG/info",
    "marketMover": "/order-trade/market-mover",
    "topBroker": "/order-trade/broker/top",
    "stockChart": "/charts/{symbol}/daily",
    "stockInfo": "/emitten/{symbol}/info",
    "stockKeystats": "/keystats/ratio/v1/{symbol}",
    "stockOrderbook": "/company-price-feed/v2/orderbook/companies/{symbol}",
    "stockForeignDomestic": "/findata-view/foreign-domestic/v1/chart-data/{symbol}",
    "stockBrokerSummary": "/marketdetectors/{symbol}",
    "paywallIncrement": "/paywall/counter/increment",
    "paywallCheck": "/paywall/eligibility/check",
    "marketSummary": "/v2/market/summary",
    "screenerPresets": "/screener/preset",
    "screenerTemplate": "/screener/templates/{id}",
    "stockSubsidiary": "/emitten-metadata/subsidiary/{symbol}",
    "stockProfile": "/emitten/{symbol}/profile",
    "insiderMajorHolder": "/insider/company/majorholder",
    "comparisonRatios": "/comparison/v2/ratios",
    "financials": "/findata-view/v2/financials/{symbol}"
  },
  "marketMoverFilterStocks": [
    "FILTER_STOCKS_TYPE_MAIN_BOARD",
    "FILTER_STOCKS_TYPE_DEVELOPMENT_BOARD",
    "FILTER_STOCKS_TYPE_ACCELERATION_BOARD",
    "FILTER_STOCKS_TYPE_NEW_ECONOMY_BOARD"
  ],
  "cacheTtlSeconds": 30,
  "proxyPort": 8001,
  "backendPort": 3001,
  "frontendPort": 3000
}
